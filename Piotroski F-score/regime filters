#SPY 200 day moving average
from AlgorithmImports import *
from datetime import timedelta


class TrendGatedAlphaModel(AlphaModel):
    """
    Regime Filter 1 — 200-day SMA trend gate.
    Emits UP insights only when SPY is trading above its 200-day SMA.
    When SPY is below the SMA, returns an empty list (go to cash).
    """

    def __init__(self, algo: QCAlgorithm):
        self.algo = algo

    def update(self, algo: QCAlgorithm, data: Slice) -> list:
        if not self.algo.sma200.IsReady:
            return []

        spy_price = algo.Securities[self.algo.spy].Price

        # Risk-off: SPY below 200-day SMA — no longs, stay in cash
        if spy_price < self.algo.sma200.Current.Value:
            algo.Log(f"SMA filter: SPY {spy_price:.2f} < SMA200 {self.algo.sma200.Current.Value:.2f} — risk-off")
            return []

        # Risk-on: emit UP insight for every active security
        insights = []
        for symbol in algo.ActiveSecurities.Keys:
            if symbol == self.algo.spy:
                continue
            insights.append(
                Insight.Price(symbol, timedelta(30), InsightDirection.UP)
            )
        return insights


class PiotroskiWithSMAFilter(QCAlgorithm):
    def initialize(self):
        self.set_cash(10_000_000)
        self.set_start_date(self.end_date - timedelta(5 * 365))

        # Add SPY for the regime filter
        self.spy = self.add_equity("SPY", Resolution.DAILY).symbol
        self.sma200 = self.SMA(self.spy, 200, Resolution.DAILY)

        rebalance_date = self.date_rules.month_start("SPY")

        self.universe_settings.schedule.on(rebalance_date)
        self.universe_settings.resolution = Resolution.HOUR
        self.settings.rebalance_portfolio_on_insight_changes = False

        self.add_universe_selection(
            PiotroskiScoreUniverseSelectionModel(
                self,
                self.get_parameter("score_threshold", 8),
                self.get_parameter("max_universe_size", 100),
            )
        )

        # Swap ConstantAlphaModel for the trend-gated version
        self.add_alpha(TrendGatedAlphaModel(self))

        self.set_portfolio_construction(
            EqualWeightingPortfolioConstructionModel(rebalance_date)
        )
        self.set_execution(SpreadExecutionModel(0.01))
        self.set_warm_up(timedelta(3 * 365))















#vix gate
from AlgorithmImports import *
from datetime import timedelta


class PiotroskiWithVIXFilter(QCAlgorithm):
    """
    Regime Filter 2 — VIX volatility gate.
    Liquidates all positions when the VIX spikes above a threshold (default 25).
    Re-enters on the next monthly rebalance if VIX has normalised.
    """

    def initialize(self):
        self.set_cash(10_000_000)
        self.set_start_date(self.end_date - timedelta(5 * 365))

        # VIX data feed
        self.vix = self.add_data(CBOE, "VIX", Resolution.DAILY).symbol
        self.vix_threshold = self.get_parameter("vix_threshold", 25)

        rebalance_date = self.date_rules.month_start("SPY")

        self.universe_settings.schedule.on(rebalance_date)
        self.universe_settings.resolution = Resolution.HOUR
        self.settings.rebalance_portfolio_on_insight_changes = False

        self.add_universe_selection(
            PiotroskiScoreUniverseSelectionModel(
                self,
                self.get_parameter("score_threshold", 8),
                self.get_parameter("max_universe_size", 100),
            )
        )

        self.add_alpha(ConstantAlphaModel(InsightType.PRICE, InsightDirection.UP, timedelta(30)))
        self.set_portfolio_construction(
            EqualWeightingPortfolioConstructionModel(rebalance_date)
        )
        self.set_execution(SpreadExecutionModel(0.01))
        self.set_warm_up(timedelta(3 * 365))

    def on_data(self, data: Slice):
        # Check VIX on every daily bar
        if not data.ContainsKey(self.vix):
            return

        vix_val = data[self.vix].Value

        if vix_val > self.vix_threshold:
            # Risk-off: volatility spike — liquidate all longs, move to cash
            if self.invested:
                self.liquidate()
                self.log(f"VIX filter: VIX={vix_val:.1f} > {self.vix_threshold} — liquidated, risk-off")











#credit spread
from AlgorithmImports import *
from datetime import timedelta


class CreditGatedAlphaModel(AlphaModel):
    """
    Regime Filter 3 — Credit spread gate (HYG vs IEF).
    Uses 63-day (≈3-month) rate-of-change to compare high-yield credit (HYG)
    against intermediate Treasuries (IEF).

    Risk-on  : HYG outperforming IEF → credit spreads tightening → safe to hold longs.
    Risk-off : IEF outperforming HYG → credit stress rising → go to cash.

    Why this matters for Piotroski:
    When credit stress is high, fundamentally weak companies can't refinance — value
    stocks become value traps and the F-Score's accounting signals lose predictive power.
    """

    def __init__(self, algo: QCAlgorithm):
        self.algo = algo

    def is_credit_risk_on(self) -> bool:
        if not (self.algo.hyg_roc.IsReady and self.algo.ief_roc.IsReady):
            return True  # Default to risk-on during warm-up
        return self.algo.hyg_roc.Current.Value > self.algo.ief_roc.Current.Value

    def update(self, algo: QCAlgorithm, data: Slice) -> list:
        if not self.is_credit_risk_on():
            algo.Log(
                f"Credit filter: HYG ROC={self.algo.hyg_roc.Current.Value:.4f} "
                f"< IEF ROC={self.algo.ief_roc.Current.Value:.4f} — risk-off"
            )
            return []

        insights = []
        for symbol in algo.ActiveSecurities.Keys:
            if symbol in (self.algo.hyg, self.algo.ief):
                continue
            insights.append(
                Insight.Price(symbol, timedelta(30), InsightDirection.UP)
            )
        return insights


class PiotroskiWithCreditFilter(QCAlgorithm):
    def initialize(self):
        self.set_cash(10_000_000)
