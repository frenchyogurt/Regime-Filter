# Add to initialize():
self._hyg = self.add_equity("HYG", Resolution.DAILY).symbol
self._ief = self.add_equity("IEF", Resolution.DAILY).symbol
# Track rolling ratio with a RollingWindow
self._ratio_window = RollingWindow[float](50)
self.schedule.on(
    self.date_rules.every_day("HYG"),
    self.time_rules.after_market_open("HYG", 1),
    self._update_credit_ratio
)

def _update_credit_ratio(self):
    hyg = self.securities[self._hyg].price
    ief = self.securities[self._ief].price
    if hyg > 0 and ief > 0:
        self._ratio_window.add(hyg / ief)

def _credit_regime_ok(self) -> bool:
    if not self._ratio_window.is_ready:
        return True  # warm-up: allow trading
    ratio_50_avg = np.mean([self._ratio_window[i]
                            for i in range(50)])
    current_ratio = self._ratio_window[0]
    return current_ratio >= ratio_50_avg

